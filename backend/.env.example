# Database (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# JWT
ACCESS_TOKEN_SECRET=your-256-bit-random-secret-here

# App URLs
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# SMTP (Gmail App Password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Local Postgres via docker-compose (only when self-hosting the DB; prod uses Neon)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-local-password
POSTGRES_DB=probalance
